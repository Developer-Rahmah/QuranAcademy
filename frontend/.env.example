# Supabase Configuration
# Get these values from your Supabase project settings (Settings > API)

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (Public) Key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Complaints / Suggestions backend
# Base URL of the side service in `backend/complaints-api/`. The
# FeedbackModal POSTs to `${VITE_COMPLAINTS_API_URL}/api/complaint`,
# which forwards messages to the configured Telegram admin chats.
# Leave empty in local dev if you don't want to run the side service —
# the modal will surface a "service not configured" toast.
# Never put TELEGRAM_BOT_TOKEN or chat ids here — those live in the
# backend service's env only.
VITE_COMPLAINTS_API_URL=https://your-complaints-api.vercel.app
