# Telegram bot token issued by @BotFather. Treat as a secret — never
# commit, never expose to the frontend bundle. Rotate via /revoke if
# leaked.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat ids that should receive each message.
# A chat id is the numeric id of an admin user OR a group (groups are
# negative). Example for two admins + one group:
#   ADMIN_CHAT_IDS=123456789,987654321,-1001234567890
ADMIN_CHAT_IDS=

# Optional. Comma-separated list of origins allowed to POST /api/complaint
# (CORS). Defaults to "*". Set to your production domain in prod, e.g.
#   ALLOWED_ORIGINS=https://www.wahdaynakacademy.com,https://wahdaynakacademy.com
ALLOWED_ORIGINS=

# Optional. Local Express port. Vercel ignores this.
PORT=3000

# Optional. WhatsApp number used by the fallback `whatsappText`. E.164
# digits only (no `+`, no spaces). Leave blank to omit the wa.me link.
WHATSAPP_NUMBER=
